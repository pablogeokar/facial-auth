{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ]
}